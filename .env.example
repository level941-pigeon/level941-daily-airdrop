# Solana RPC endpoint. Must support getProgramAccounts (Helius, QuickNode, Triton).
RPC_URL=

# SPL token mint address. Classic SPL and Token-2022 both work. Program is auto-detected.
TOKEN_MINT=

# Dedicated airdrop wallet only. Solana JSON keypair array or base58 secret key.
# Never commit this file. Never put treasury keys here.
AIRDROP_PRIVATE_KEY=

# Human token amounts, not raw units. The script converts using on-chain decimals.
SCHEDULED_DAILY_DRIP_AMOUNT=
MINIMUM_HOLDER_BALANCE=0

# Comma separated wallets to exclude: team, LP, pools, CEX.
# The sender wallet is excluded automatically.
EXCLUDED_WALLETS=

HOLDER_GOAL=94100
RETAINED_SUPPLY_PERCENT=15
MAX_AIRDROP_POOL_PERCENT=50

# Optional. Delay between transfers in ms, and priority fee in micro lamports.
SEND_DELAY_MS=300
PRIORITY_FEE_MICROLAMPORTS=0

# Distribution weighting.
# streak:  weight = balance x consecutive snapshot days without selling, capped.
# prorata: weight = balance only.
# equal:   same amount per wallet. Sybil-vulnerable. Reference only.
DISTRIBUTION_MODE=streak
STREAK_CAP=94

# Auto mode tripwires. send-auto halts instead of sending if any trips.
AUTO_MIN_HOLDERS=50
AUTO_MAX_HOLDER_DROP_PERCENT=25
AUTO_MAX_TOP_SHARE_PERCENT=50

# Community drop sweep. Only these mints ever leave the wallet via sweep.
# The main token never sweeps. Unknown tokens are quarantined and reported.
ALLOWED_DROP_MINTS=
SWEEP_TOP_N=100

# Drop pipeline. Unknown tokens: screen, cool SWEEP_DELAY_HOURS, then must
# quote above SWEEP_MIN_USD realizable to auto-sweep. SOL above SOL_RESERVE
# sweeps when excess passes 0.5. Webhook gets every event on your phone.
SWEEP_MIN_USD=100
SWEEP_DELAY_HOURS=48
SOL_RESERVE=0.3
JUP_QUOTE_URL=https://lite-api.jup.ag/swap/v1/quote
DISCORD_WEBHOOK_URL=

# Optional second webhook for a PUBLIC channel. Gets only curated events:
# daily totals, new bread detected, sweeps. Never errors, never diagnostics.
DISCORD_PUBLIC_WEBHOOK_URL=

# Any balance drop between snapshots removes a wallet from all payouts for
# this many days, streak resets too. 0 disables. They still count toward
# the curve, their share pays everyone who held.
SELLER_TIMEOUT_DAYS=2

# OG bridge. Inert until data/og/og-all-snapshot.csv exists and the window
# dates are set. Eligible: replay wallets with BRIDGE_MIN_OG_DAYS+, plus
# any wallet in data/og/locked-positions.csv (verified locks, full import).
BRIDGE_MIN_OG_DAYS=90
BRIDGE_BONUS_TOKENS=5313
BRIDGE_OPEN_DATE=
BRIDGE_CLOSE_DATE=



# Snapshot safety: if positive-holder count drops more than this percent
# versus the prior run, abort rather than mass-reset streaks on a partial
# RPC response. Raise deliberately only for a real mass exit.
SNAPSHOT_MAX_DROP_PERCENT=50

# Loyalty capstone: the N longest-held wallets each get a fixed bonus,
# ranked by streak alone (size ignored), gated at the 10k floor, funded
# from the Box and bounded by curve headroom.
LOYALTY_WINNERS=94
LOYALTY_BONUS_TOKENS=25000
# Pay with an event id so reruns never double-pay:
#   LOYALTY_EVENT_ID=2026-07-20-capstone npm run loyalty-pay

# Founder drop: an operator-triggered distribution from founder supply,
# NOT box emission. Excluded from curve accounting. Hard-guarded against
# the RETAINED_SUPPLY_PERCENT cold floor. Idempotent by event id:
#   FOUNDER_EVENT_ID=2026-07-15-founder-seed npm run founder-pay
FOUNDER_DROP_TOKENS=25000
