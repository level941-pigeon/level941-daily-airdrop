# ---- 941 draw, commit-settle. Never reuse the drop wallet. ----
# A dedicated draw wallet, funded from buyback proceeds only.
DRAW_WALLET_KEY=
# Prize and winners (config defaults: 941000 tokens, 1 winner).
DRAW_PRIZE_TOKENS=941000
DRAW_WINNERS=1
#
# PHASE 1, commit (before entropy exists):
#   DRAW_ROUND_ID=2026-07-18-941 \
#   DRAW_SEED_SOURCE="first finalized Solana blockhash after 2026-07-19T00:00Z" \
#   npm run draw-commit
# Publish round id, eligibility hash, prize, and seed source.
#
# PHASE 2, settle (after that blockhash exists):
#   DRAW_ROUND_ID=2026-07-18-941 \
#   DRAW_ENTROPY=<the actual blockhash> \
#   npm run draw-settle
# Winners are written publicly BEFORE any payment. Rerun-safe.
